# New, SEPARATE Postgres database (do not reuse nfl26's)
DATABASE_URL="postgresql://USER:PASS@HOST/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASS@HOST/DB?sslmode=require"
# NextAuth JWT secret: generate with `openssl rand -base64 32`
AUTH_SECRET=""
# Email that is auto-granted admin + auto-approved on signup
ADMIN_EMAIL=""
# Base URL for password-reset links
APP_URL="http://localhost:3000"
# Optional: Gmail SMTP for password-reset email (degrades if unset)
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
# Optional: Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX). Analytics loads only when set.
NEXT_PUBLIC_GA_ID=""
# Secret guarding the automated results-refresh cron (/api/cron/refresh).
# Generate with `openssl rand -base64 32`. Set the SAME value in Vercel → Production.
# Vercel Cron sends it automatically as `Authorization: Bearer <CRON_SECRET>`.
# If unset, the cron endpoint fails closed (401) — results won't auto-refresh.
CRON_SECRET=""
